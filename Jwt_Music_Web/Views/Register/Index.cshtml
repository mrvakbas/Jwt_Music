@model RegisterDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Register - Bepop Music Platform</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Spline+Sans:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet" />
    <style>
            :root {
                --primary-purple: #895af6;
                --bg-dark: #0f1115;
                --card-bg: #1a1d23;
                --border-radius: 8px;
            }

            body {
                background-color: var(--bg-dark);
                color: #ffffff;
                font-family: 'Spline Sans', sans-serif;
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
            }

            .auth-card {
                background-color: var(--card-bg);
                border: 1px solid rgba(255, 255, 255, 0.05);
                border-radius: var(--border-radius);
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
                width: 100%;
                max-width: 1100px;
            }

            .brand-section {
                background: linear-gradient(rgba(15, 17, 21, 0.7), rgba(15, 17, 21, 0.7)), url('https://images.unsplash.com/photo-1514525253361-bee8a48790c3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80');
                background-size: cover;
                background-position: center;
                height: 100%;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 3rem;
            }

            .form-control {
                background-color: #252830;
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: #fff !important;
                border-radius: var(--border-radius);
                padding: 0.65rem 1rem;
            }

                .form-control:focus {
                    background-color: #2a2d36;
                    border-color: var(--primary-purple);
                    box-shadow: 0 0 0 0.25rem rgba(137, 90, 246, 0.25);
                }

            .btn-primary {
                background-color: var(--primary-purple);
                border-color: var(--primary-purple);
                padding: 0.75rem;
                font-weight: 600;
            }

            .package-option {
                cursor: pointer;
                display: block;
            }

            .package-card {
                border: 2px solid rgba(255,255,255,0.05);
                background: #252830;
                border-radius: var(--border-radius);
                padding: 1.2rem 0.5rem;
                text-align: center;
                transition: all 0.2s ease;
            }

                .package-card:hover {
                    background: #2e323b;
                }

            input[type="radio"]:checked + .package-card {
                border-color: var(--primary-purple);
                background: rgba(137, 90, 246, 0.15);
                transform: translateY(-2px);
            }

            .text-purple {
                color: var(--primary-purple);
            }

            .validation-msg {
                font-size: 0.75rem;
                color: #ff6b6b;
                display: block;
                margin-top: 4px;
            }
    </style>
</head>
<body>

    <div class="container py-4">
        <div class="auth-card mx-auto">
            <div class="row g-0">
                <div class="col-lg-4 d-none d-lg-block">
                    <div class="brand-section">
                        <div class="mb-4">
                            <span class="h4 fw-bold text-purple">Bepop</span>
                        </div>
                        <h1 class="display-6 fw-bold mb-3">Müziğin Geleceğine Katıl.</h1>
                        <p class="opacity-75">Kendi profilini oluştur, paketini seç ve topluluğun bir parçası ol.</p>
                    </div>
                </div>

                <div class="col-lg-8 p-4 p-md-5">
                    <div class="mb-4">
                        <h2 class="fw-bold">Kayıt Ol</h2>
                        <p class="text-secondary small">Bilgilerini gir ve sana en uygun paketi seç.</p>
                    </div>

                    <form method="post">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label small text-secondary" asp-for="FullName">Ad Soyad</label>
                                <input asp-for="FullName" class="form-control" placeholder="Adınız Soyadınız" />
                                <span asp-validation-for="FullName" class="validation-msg"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label small text-secondary" asp-for="Username">Kullanıcı Adı</label>
                                <input asp-for="Username" class="form-control" placeholder="kullaniciadi" />
                                <span asp-validation-for="Username" class="validation-msg"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label small text-secondary" asp-for="ImageUrl">Resim Url</label>
                                <input asp-for="ImageUrl" class="form-control" placeholder="Resim Url" />
                                <span asp-validation-for="ImageUrl" class="validation-msg"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-secondary" asp-for="Email">E-posta</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="ornek@mail.com" />
                            <span asp-validation-for="Email" class="validation-msg"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-secondary" asp-for="Password">Şifre</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="validation-msg"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small text-secondary d-block mb-3">Bir Paket Seçin</label>
                            <div class="row g-2">
                                <div class="col-4">
                                    <label class="package-option">
                                        <input type="radio" asp-for="PackageId" value="1" class="d-none" checked />
                                        <div class="package-card">
                                            <div class="fw-bold small">Free</div>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-4">
                                    <label class="package-option">
                                        <input type="radio" asp-for="PackageId" value="2" class="d-none" />
                                        <div class="package-card">
                                            <div class="fw-bold small">Basic</div>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-4">
                                    <label class="package-option">
                                        <input type="radio" asp-for="PackageId" value="3" class="d-none" />
                                        <div class="package-card">
                                            <div class="fw-bold small">Standard</div>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-4">
                                    <label class="package-option">
                                        <input type="radio" asp-for="PackageId" value="4" class="d-none" />
                                        <div class="package-card">
                                            <div class="fw-bold small">Gold</div>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-4">
                                    <label class="package-option">
                                        <input type="radio" asp-for="PackageId" value="5" class="d-none" />
                                        <div class="package-card">
                                            <div class="fw-bold small">Premium</div>
                                        </div>
                                    </label>
                                </div>
                                <div class="col-4">
                                    <label class="package-option">
                                        <input type="radio" asp-for="PackageId" value="6" class="d-none" />
                                        <div class="package-card">
                                            <div class="fw-bold small">Elite</div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <span asp-validation-for="PackageId" class="validation-msg"></span>
                        </div>

                        <div class="d-grid mb-3">
                            <button class="btn btn-primary" type="submit">Kayıt İşlemini Tamamla</button>
                        </div>

                        <p class="text-center text-secondary small">
                            Zaten üye misiniz? <a href="/Login/Index" class="text-purple fw-bold text-decoration-none">Giriş Yap</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>