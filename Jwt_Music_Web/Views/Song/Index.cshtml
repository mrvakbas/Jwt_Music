@model List<ResultSongDto>

@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "~/Views/Shared/_Layout.cshtml";
}

<div class="page-content page-container" id="page-content">
    <div class="padding" id="list" data-plugin="list">
        <div class="pos-rlt">
            <div class="py-5">
                <!-- Filtre Başlığı -->
                <div class="heading pt-5 pb-3 d-flex align-items-center">
                    <div>
                        <h5 class="text-highlight">Müzik Keşfet</h5>
                        <p class="text-muted">Ülke ve türe göre filtreleyin</p>
                    </div>
                    <span class="flex"></span>

                </div>

                <!-- Filtre Butonları -->
                <div class="mb-4">
                    <!-- Ülke Filtreleri -->
                    <div class="mb-3">
                        <h6 class="text-white mb-2">
                            <i data-feather="map-pin" width="16" height="16" class="me-1"></i>
                            Ülkeler
                        </h6>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm filter-btn active" data-type="country" data-value="all">
                                <i data-feather="globe" width="14" height="14"></i> Tüm Ülkeler
                            </button>
                            @if (ViewBag.allCountries != null)
                            {
                                @foreach (var item in ViewBag.allCountries)
                                {
                                    <button class="btn btn-sm btn-outline-light filter-btn" data-type="country" data-value="@item.Country">
                                        @item.Country
                                    </button>
                                }
                            }
                        </div>
                    </div>

                    <!-- Tür Filtreleri -->
                    <div class="mb-3">
                        <h6 class="text-white mb-2">
                            <i data-feather="music" width="16" height="16" class="me-1"></i>
                            Türler
                        </h6>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm filter-btn active" data-type="genre" data-value="all">
                                <i data-feather="disc" width="14" height="14"></i> Tüm Türler
                            </button>
                            @if (ViewBag.allGenres != null)
                            {
                                @foreach (var item in ViewBag.allGenres)
                                {
                                    <button class="btn btn-sm btn-outline-light filter-btn" data-type="genre" data-value="@item.Genre">
                                        @item.Genre
                                    </button>
                                }
                            }
                        </div>
                    </div>
                </div>

                <!-- Şarkı Listesi Container - KART GÖRÜNÜMÜ İÇİN PARTIAL -->
                <div id="chart-list-container">
                    @* @await Html.PartialAsync("_SongListPartial", Model) *@
                </div>
            </div>
        </div>
    </div>
</div>
