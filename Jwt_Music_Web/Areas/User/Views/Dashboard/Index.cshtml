@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}

<div class="topbar">
    <div class="topbar-left">
        <div style="display:flex;align-items:center;gap:12px;">
            <button class="hamburger" id="hamburger" title="Menüyü aç">
                <svg viewBox="0 0 18 18">
                    <line x1="2" y1="5" x2="16" y2="5" />
                    <line x1="2" y1="9" x2="16" y2="9" />
                    <line x1="2" y1="13" x2="16" y2="13" />
                </svg>
            </button>
            <div>
                <div class="page-title">Genel Bakış</div>
                <div class="page-sub">Son 30 gün · Mart 2026</div>
            </div>
        </div>
    </div>
    <div class="topbar-right">
        <select class="pill" style="appearance:none;cursor:pointer;">
            <option>Son 30 gün</option>
            <option>Son 7 gün</option>
            <option>Bu yıl</option>
        </select>
        <button class="btn">+ Rapor Ekle</button>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-label">En Çok Tıklanan</div>
        <div class="kpi-value">@ViewBag.maxClick</div>
        <div class="kpi-trend up">↑ %12.4 geçen aya göre</div>
        <div class="kpi-sparkline"><canvas id="spark1"></canvas></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Toplam Albüm</div>
        <div class="kpi-value">@ViewBag.albumCount</div>
        <div class="kpi-trend up">↑ %5.1 geçen aya göre</div>
        <div class="kpi-sparkline"><canvas id="spark2"></canvas></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">Toplam Şarkı</div>
        <div class="kpi-value">@ViewBag.songCount</div>
        <div class="kpi-trend up">↑ 22 sn arttı</div>
        <div class="kpi-sparkline"><canvas id="spark4"></canvas></div>
    </div>
</div>

<div class="bottom-row">

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">En Popüler 5 Şarkı (Tıklanma Analizi)</h6>
        </div>
        <div class="card-body">
            <div class="chart-bar">
                <canvas id="mySongsChart" style="max-height: 400px;"></canvas>
            </div>
            <hr>
            <div class="text-center">
                <span class="badge badge-info">
                    <i class="fas fa-robot"></i> Yapay Zeka Tahmini Başarı Skoru: @ViewBag.EstimatedSuccess
                </span>
            </div>
        </div>
    </div>

</div>

<div class="bottom-row" style="margin-top:20px;">
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Aylık Aktivite Trendi (Son 30 Gün)</h6>
        </div>
        <div class="card-body">
            <canvas id="monthTrendChart" style="height: 300px;"></canvas>
        </div>
    </div>
</div>
