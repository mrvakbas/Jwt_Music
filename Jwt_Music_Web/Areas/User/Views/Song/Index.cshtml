@using Jwt_Music.Entities
@model List<Song>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
    ViewBag.Songs = Model;
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark">Şarkı Analizi</h2>
            <p class="text-muted">Sistemdeki tüm şarkıların performansını ve tıklanma verilerini buradan yönetebilirsiniz.</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                        <svg width="24" height="24" fill="#4e73df" viewBox="0 0 16 16">
                            <path d="M8 1L10 6H15L11 9L13 14L8 11L3 14L5 9L1 6H6Z" />
                        </svg>
                    </div>
                    <div>
                        <div class="text-muted small">Toplam Şarkı</div>
                        <div class="fs-4 fw-bold">@Model.Count</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
                        <svg width="24" height="24" fill="#1cc88a" viewBox="0 0 16 16">
                            <path d="M11 2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V2zM5 5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V5zm-4 4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V9z" />
                        </svg>
                    </div>
                    <div>
                        <div class="text-muted small">Toplam Dinlenme</div>
                        <div class="fs-4 fw-bold">@Model.Sum(x => x.ClickCount).ToString("N0")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">Popülerlik Grafiği</h6>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="mySongsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-dark">Tüm Şarkılar</h6>
            <a href="/User/Song/Create" class="btn btn-primary btn-sm rounded-pill px-3">+ Yeni Şarkı</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#ID</th>
                        <th>Şarkı Adı</th>
                        <th>Dinlenme</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">#@item.Id</td>
                            <td>
                                <div class="fw-medium">@item.Title</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-primary border">
                                    @item.ClickCount.ToString("N0")
                                </span>
                            </td>
                            <td class="text-end">
                                <a href="/User/Song/Edit/@item.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                                <button class="btn btn-sm btn-outline-danger ms-1">Sil</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>